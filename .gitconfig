[user]
	name = evan slack
	email = evan.slack@tufts.edu
[credential]
	helper = /mnt/c/Program\\ Files/Git/mingw64/libexec/git-core/git-credential-manager-core.exe
[core]
	editor = vim
[color]
  	branch = auto
  	diff = auto
  	interactive = auto
 	status = auto
[web]
	browser = google-chrome
[pull]
	rebase = true
[alias]
	graph = log --oneline --graph --decorate
	co = checkout
	